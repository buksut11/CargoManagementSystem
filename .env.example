# Copy this file to .env.local and fill in the values.

# ── Supabase (required) ──────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Powers invite acceptance and Stripe webhooks.
# Never expose this to the browser (no NEXT_PUBLIC_ prefix). Dashboard → API.
SUPABASE_SERVICE_ROLE_KEY=

# ── Site URL (recommended in production) ─────────────────────────────────────
# The canonical https URL of this deployment, e.g. https://app.yourco.com.
# Used to build absolute links in invite emails and Stripe redirects so they
# can never be influenced by request headers. Falls back to the request URL.
NEXT_PUBLIC_APP_URL=

# ── Stripe (optional — only needed to turn on billing) ───────────────────────
# Leave blank to run without billing. Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The price customers subscribe to (Dashboard → Products). One tier for now.
STRIPE_PRICE_ID=

# ── Pro-plan price (optional) ────────────────────────────────────────────────
# What every payment provider charges to upgrade an org to Pro. Keep in step
# with the price label shown on the billing cards (lib/plans.ts). Default 25 USD.
BILLING_PLAN_AMOUNT=
BILLING_CURRENCY=

# ── Payment providers (optional — Somali mobile money & banking) ─────────────
# Each provider is a SEPARATE gateway with its own SERVER-ONLY secrets (never
# prefix with NEXT_PUBLIC_). Any provider left blank shows "not configured" on
# its billing card and is skipped; fill in the ones you have merchant accounts
# for. All three upgrade the org to the Pro plan on a successful charge.

# EVC Plus — Hormuud, via WaafiPay (api.waafipay.net). Register at waafi.com.
# WAAFI_API_URL is optional (points at the sandbox while testing).
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=
WAAFI_API_URL=

# eDahab — Somtel / Dahabshiil (edahab.net). Confirm the exact request fields
# and hash recipe against the merchant docs you receive. EDAHAB_API_URL optional.
EDAHAB_API_KEY=
EDAHAB_API_SECRET=
EDAHAB_AGENT_CODE=
EDAHAB_API_URL=

# Premier Bank — Premier Wallet merchant API. PREMIER_API_URL is the base URL
# from your integration guide (no default); adjust the request in lib/premier.ts
# to match their docs.
PREMIER_API_URL=
PREMIER_API_KEY=
PREMIER_MERCHANT_ID=

# ── Billing lifecycle cron (required for monthly billing) ────────────────────
# Protects /api/billing/cron, the daily heartbeat that opens monthly invoices,
# sends renewal reminders, starts the 3-day grace period and freezes unpaid
# orgs. Any long random string. On Vercel, setting this env var makes Vercel
# Cron (see vercel.json) authenticate automatically; elsewhere call the route
# daily yourself:  curl -H "Authorization: Bearer $CRON_SECRET" …/api/billing/cron
CRON_SECRET=

# ── Billing notification email (optional — any SMTP provider) ────────────────
# Plain SMTP, so it works with Gmail, Outlook, Zoho, or your own mail server.
# Leave blank to keep billing notifications in-app (and WhatsApp) only.
# SMTP_PORT defaults to 587 (STARTTLS); use 465 for implicit TLS.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# The "From" address, e.g.  CargoBook Billing <billing@yourco.com>
SMTP_FROM=

# ── Billing notification WhatsApp (optional — Meta WhatsApp Cloud API) ───────
# From a Meta Business app with the WhatsApp product enabled: a permanent
# system-user access token and the sender phone number's id. Reminders go to
# each organization's contact phone (Settings → Organization → Phone).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Recommended: a pre-approved message template with two body parameters
# ({{1}} = title, {{2}} = body) so reminders deliver outside the 24-hour
# customer-service window. Without it, plain text messages are attempted.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=

# ── Email (optional — turns invite links into automatic emails) ──────────────
# Leave blank to keep sharing invite links manually. Get a key at resend.com.
RESEND_API_KEY=
# The "From" address. resend.dev works for testing (only to your own email);
# verify your own domain to email teammates. e.g. CargoBook <invites@yourco.com>
RESEND_FROM=
